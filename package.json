{
  "name": "reamlet",
  "version": "0.2.4",
  "description": "Lightweight standalone PDF viewer for Windows",
  "main": "out/main.js",
  "packageManager": "pnpm@10.32.1",
  "author": "Nick Hespe",
  "scripts": {
    "clean": "node -e \"['out','dist','native-host/dist'].forEach(d => require('fs').rmSync(d, { recursive: true, force: true }))\"",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json",
    "build-native-host": "node node_modules/pkg/lib-es5/bin.js native-host/host.js --target node18-win-x64 --output native-host/dist/reamlet-native-host.exe",
    "start": "pnpm run build && electron out/main.js",
    "dist": "pnpm run build && electron-builder --win portable",
    "build-win": "pnpm run build && pnpm run build-native-host && electron-builder --win nsis portable --x64",
    "build-mac": "pnpm run build && electron-builder --mac dmg --universal"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.4.168"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "pkg": "^5.8.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.1"
  },
  "build": {
    "appId": "com.reamlet.app",
    "productName": "Reamlet",
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "Open with Reamlet",
        "role": "Viewer",
        "icon": "assets/icon.ico"
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "extraFiles": [
        {
          "from": "native-host/dist/reamlet-native-host.exe",
          "to": "reamlet-native-host.exe"
        },
        {
          "from": "native-host/com.reamlet.chromebridge.json",
          "to": "com.reamlet.chromebridge.json"
        },
        {
          "from": "native-host/register-host.bat",
          "to": "register-host.bat"
        },
        {
          "from": "native-host/unregister-host.bat",
          "to": "unregister-host.bat"
        }
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "out/**/*",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "license": "GPL-3.0-or-later"
}
