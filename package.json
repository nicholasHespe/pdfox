{
  "name": "pdfox",
  "version": "0.1.0",
  "description": "Lightweight standalone PDF viewer for Windows",
  "main": "main.js",
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "dist": "electron-builder --win portable",
    "build-win": "electron-builder --win nsis portable --x64"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.4.168"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.pdfox.app",
    "productName": "PDFox",
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "Open with PDFox",
        "role": "Viewer",
        "icon": "assets/pdfox_logo.ico"
      }
    ],
    "win": {
      "icon": "assets/pdfox_logo.ico",
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "license": "GPL-3.0-or-later"
}
